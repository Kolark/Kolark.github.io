<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/normalize.css" />
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/about.css" />
    <link rel="stylesheet" href="/css/project.css">
    <link rel="stylesheet" href="/css/footer.css" />
    <title>{{title}}</title>
</head>
<body class="b-inside">
    <!-- START BARBA -->
	<div data-barba="wrapper">
    <div data-barba="container" data-barba-namespace="project">
    <!-- START ASSCROLL  -->
    <div asscroll-container>
        
    <div class="scroll-wrap">
    <!--START CONTENT  -->

    <div class="project__content">

        <header class="header">
            <div class="header_content">
                <div class="about__link">
                    <a href="/"><h2>About</h2></a>
                </div>
                <div class="contact">
                    <ul class="contact__links">
                        <li><a href="https://github.com/Kolark" target="_blank" ><h2>Github</h2></a></li>
                        <li><a href="mailto:felipe.loaizama@gmail.com" target="_blank"><h2>Email</h2></a></li>
                        <li><a href="https://www.linkedin.com/in/felipe-loaiza-199754211/" target="_blank"><h2>Linkedin</h2></a></li>
                    </ul>
                </div>
            </div>
        </header>
        <main class="main">
            <div class="project">
                <div class="project__overview">
                    <div class="project__title">
                        <h1>{{title}}</h1>
                    </div>
                    <div class="project__description">
                        <p>{{description}}</p>
                    </div>
                    <div class="project__links">
                        <h3>Skills Used</h3>
                        {% if skills %}
                        <div class="">{{ skills | arrayToClasses }}</div>
                        {% endif %}
                        {% if links %}
                        <h3>Links</h3>
                        <ul class="project__links-list">
                            {% for li in links %}
                            <li><a href="{{li.href}}" target="_blank">{{li.name}}</a></li>
                            {% endfor %}
                        </ul>
                        {% endif %}
                    </div>
                </div>
                <div class="project__images">
                    {% if project_images %}
                    {% for img in project_images %}
                    <div class="project_img">
                        <img src="/img/{{img}}" alt="">
                    </div>
                    {% endfor %}
                    {% endif %}
                </div>
            </div>
        </main>
    </div>
    <!-- END CONTENT -->
    </div>
    </div>
    <!-- END ASSCROLL -->
	</div>
    </div>
    <!-- END BARBA -->

    <div class="curtain"></div>
</body>
<script src="/index.js"></script>
</html>