<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/normalize.css" />
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/project.css">
    <title>{{title}}</title>
</head>
<body>
    <header class="header">
        <div class="about__link">
            <a href=""><h2>About</h2></a>
        </div>
        <div class="contact">
            <ul class="contact__links">
                <li><a href=""><h2>Email</h2></a></li>
                <li><a href=""><h2>Github</h2></a></li>
                <li><a href=""><h2>Linkedin</h2></a></li>
            </ul>
        </div>
    </header>
    <main class="main">
        <div class="project">
            <div class="project__title">
                <h1>{{title}}</h1>
            </div>
            <div class="project__description">
                <p>{{description}}</p>
            </div>
            <div class="project__links">
                {% if github %}
                <a href="{{ github}}" target="__blank">Githublink</a>
                {% endif %}
                {% if numbers %}
                <ul>
                    {% for n in numbers %}
                    <li>{{n}}</li>
                    {% endfor %}
                </ul>
                {% endif %}
                <p>Web Dev Projects</p>
                <p>C# Unity Rest Apis</p>
                <p>Github</p>
                <p>Playstore</p>
                <p>Itch.io</p>
            </div>
        </div>
    </main>
</body>
</html>